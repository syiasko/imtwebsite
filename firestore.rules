rules_version = '2';

// Public read for the showcase site; authenticated write so admin actions
// require an anonymous Firebase Auth session (the app provisions one
// automatically via signInAnonymously). Anyone may submit a contact message.
//
// Deploy via: firebase deploy --only firestore:rules
// or paste into Firebase Console → Firestore → Rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /vehicles/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /users/{id} {
      // Users are admin-only data — no public read.
      allow read, write: if request.auth != null;
    }
    match /messages/{id} {
      // Public visitors may submit a contact message; only authed sessions
      // can read or modify them after the fact.
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
