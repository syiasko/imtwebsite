rules_version = '2';

// Public read (so the showcase site loads for anyone), authenticated write
// (so admin-side updates require an anonymous Firebase Auth session, which the
// app provisions automatically via signInAnonymously).
//
// Deploy via: firebase deploy --only firestore:rules
// or paste into Firebase Console → Firestore → Rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /vehicles/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
